# Copy to .env and fill in your values

# PostgreSQL (Neon or Supabase)
# Neon example:
# DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require
# Supabase — prefer SESSION POOLER (IPv4-friendly on Windows):
# Dashboard → Project Settings → Database → Connection string → Session pooler → URI
# DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-1-ap-northeast-1.pooler.supabase.com:5432/postgres?sslmode=require
#
# Avoid db.[ref].supabase.co on Windows if you get "could not translate host name"
# (that hostname is often IPv6-only).
DATABASE_URL=postgresql://user:password@localhost:5432/orbitx

SECRET_KEY=change-me-to-a-long-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# Comma-separated origins for CORS
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

API_V1_PREFIX=/api/v1
ENVIRONMENT=development
